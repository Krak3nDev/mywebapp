{% extends "_layout.html.j2" %}
{% block title %}item {{ item.id }}{% endblock %}
{% block content %}
<h1>Item {{ item.id }}</h1>
<table>
<tr><th>id</th><td>{{ item.id }}</td></tr>
<tr><th>name</th><td>{{ item.name }}</td></tr>
<tr><th>quantity</th><td>{{ item.quantity }}</td></tr>
<tr><th>created_at</th><td>{{ item.created_at.isoformat() }}</td></tr>
</table>
{% endblock %}
