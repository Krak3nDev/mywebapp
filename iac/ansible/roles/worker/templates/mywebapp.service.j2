[Unit]
Description=mywebapp compose stack (Лабораторна №4 — Ansible-managed)
After=docker.service network-online.target
Wants=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/mywebapp
ExecStartPre=/usr/bin/docker compose -f /opt/mywebapp/compose.yaml pull
ExecStart=/usr/bin/docker compose -f /opt/mywebapp/compose.yaml up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f /opt/mywebapp/compose.yaml down
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
