# Managed by Ansible (Лабораторна №4) — nginx allow-list.
upstream mywebapp_app {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 0.0.0.0:80 default_server;
    server_name _;

    access_log /var/log/nginx/mywebapp.access.log;
    error_log  /var/log/nginx/mywebapp.error.log warn;

    # Health endpoints are internal only.
    location ^~ /health {
        return 404;
    }

    location = / {
        proxy_pass http://mywebapp_app;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /items {
        proxy_pass http://mywebapp_app;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~ ^/items/[0-9]+$ {
        proxy_pass http://mywebapp_app;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Default-deny: anything not explicitly allowed above is 404.
    location / {
        return 404;
    }
}
