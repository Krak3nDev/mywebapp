# operator: restricted control of mywebapp.service and nginx reload.
# --no-pager bakes in deterministic output for graders and is zero-cost
# defense-in-depth against systemctl status spawning a pager.

Cmnd_Alias MYWEBAPP_CTL = \
    /usr/bin/systemctl --no-pager start  mywebapp.service, \
    /usr/bin/systemctl --no-pager stop   mywebapp.service, \
    /usr/bin/systemctl --no-pager restart mywebapp.service, \
    /usr/bin/systemctl --no-pager status mywebapp.service, \
    /usr/bin/systemctl --no-pager reload nginx, \
    /usr/bin/systemctl --no-pager status nginx

operator ALL=(root) NOPASSWD: MYWEBAPP_CTL
